# Elasticsearch.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_VERIFY_CERTS=true

# Core indexes.
POSTS_INDEX=cost_living_posts_current
PROCESSED_POSTS_WRITE_INDEX=cost_living_processed_posts
CURATED_POSTS_INDEX=cost_living_processed_posts
POSTS_CURRENT_ALIAS=cost_living_posts_current
RAW_POSTS_INDEX=cost_living_raw_posts
INDICATORS_INDEX=cost_living_indicators
MONTHLY_METRICS_INDEX=cost_living_monthly_topic_metrics

# API.
API_TITLE=Cost-of-Living Data Platform API
API_CACHE_TTL_SECONDS=30

# Optional Redis runtime queue.
# When enabled, scheduled jobs emit lifecycle events and use distributed locks
# to avoid overlapping timer executions.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_PREFIX=cost_living_pipeline
REDIS_LOCK_TTL_SECONDS=900
REDIS_EVENT_TTL_SECONDS=86400
REDIS_EVENT_QUEUE_MAX_LENGTH=500

# Cost-of-living search terms used by GDELT Doc API jobs.
COST_OF_LIVING_QUERIES=cost of living Australia,rental crisis Australia,rent increase Australia,mortgage stress Australia,housing affordability Australia,electricity bills Australia,energy bills Australia,petrol prices Australia,grocery prices Australia,supermarket prices Australia,food prices Australia,inflation Australia,interest rates Australia,real wages Australia,auspol cost of living,Melbourne rent,Sydney rent,Perth rent

# ABS CPI official data.
ABS_DATA_API_BASE_URL=https://data.api.abs.gov.au/rest
ABS_CPI_DATAFLOW=ABS,CPI,2.0.0
ABS_CPI_DATA_KEY=1+3..10.50.M
ABS_CPI_LAST_N_OBSERVATIONS=60

# Bluesky stream source.
BLUESKY_STREAM_BASE_URL=https://bsky.social
BLUESKY_STREAM_HANDLE=
BLUESKY_STREAM_APP_PASSWORD=
BLUESKY_STREAM_RAW_INDEX=cost_living_bluesky_raw_stream

# Mastodon stream sources.
MASTODON_STREAM_RAW_INDEX=cost_living_mastodon_raw_stream
MASTODON_AU_BASE_URL=https://mastodon.au
MASTODON_AU_ACCESS_TOKEN=
MASTODON_SOCIAL_BASE_URL=https://mastodon.social
MASTODON_SOCIAL_ACCESS_TOKEN=
AUS_SOCIAL_BASE_URL=https://aus.social
AUS_SOCIAL_ACCESS_TOKEN=

# Stream state and GDELT GKG source indexes.
SOCIAL_HARVEST_STATE_INDEX=cost_living_harvest_state
GDELT_GKG_QUEUE_INDEX=cost_living_gdelt_gkg_file_queue
GDELT_GKG_RAW_INDEX=cost_living_gdelt_raw_stream

# Unified raw sync.
UNIFIED_RAW_SYNC_LOOKBACK_HOURS=2
UNIFIED_RAW_SYNC_SCAN_SIZE=1000
UNIFIED_RAW_SYNC_BULK_SIZE=1000
UNIFIED_RAW_SYNC_MAX_TEXT_LENGTH=10000
UNIFIED_RAW_SYNC_REQUIRE_PLATFORM_INDICES=true

# GDELT Doc API jobs.
GDELT_DOC_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_QUERIES=cost of living,rental crisis,rent increase,mortgage stress,housing affordability,electricity prices,energy bills,petrol prices,fuel prices,grocery prices,food prices,supermarket prices,inflation,real wages,interest rates
GDELT_SOURCE_COUNTRY=australia
GDELT_SOURCE_LANGUAGE=english
GDELT_TIMESPAN=1week
GDELT_LIMIT=50
GDELT_REQUEST_DELAY_SECONDS=6
GDELT_REQUEST_TIMEOUT_SECONDS=20
GDELT_RETRIES=2
GDELT_MAX_RUNTIME_SECONDS=240
GDELT_BACKFILL_MONTHS=3
GDELT_BACKFILL_WINDOW_DAYS=1
GDELT_BACKFILL_LIMIT=250
GDELT_BACKFILL_REQUEST_DELAY_SECONDS=20
GDELT_BACKFILL_REQUEST_TIMEOUT_SECONDS=30
GDELT_BACKFILL_RETRIES=3
GDELT_BACKFILL_MAX_WINDOWS=0
GDELT_BACKFILL_MAX_REQUESTS=0
GDELT_BACKFILL_STATE_PATH=data/backfill_state/gdelt_backfill.json

# NLP worker.
NLP_BATCH_SIZE=250
NLP_MAX_DOCS_PER_RUN=1000
NLP_BULK_SIZE=500
NLP_PROCESSING_STALE_MINUTES=120
