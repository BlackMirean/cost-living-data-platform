{
  "phases": {
    "hot": {
      "actions": {
        "rollover": {
          "max_age": "30d",
          "max_primary_shard_size": "2gb",
          "max_docs": 500000
        }
      }
    },
    "warm": {
      "min_age": "30d",
      "actions": {
        "forcemerge": {
          "max_num_segments": 1
        }
      }
    }
  }
}
